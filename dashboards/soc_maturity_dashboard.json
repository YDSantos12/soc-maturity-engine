          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "rule_name"},
            "properties": [{"id": "custom.width", "value": 220}]
          },
          {
            "matcher": {"id": "byName", "options": "classification"},
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "excellent": {"color": "green",  "index": 0, "text": "excellent"},
                      "good":      {"color": "blue",   "index": 1, "text": "good"},
                      "noisy":     {"color": "yellow", "index": 2, "text": "noisy"},
                      "critical":  {"color": "red",    "index": 3, "text": "critical"}
                    }
                  }
                ]
              },
              {"id": "custom.cellOptions", "value": {"type": "color-background"}}
            ]
          }
        ]
      },
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 4},
      "id": 6,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": ["sum"],
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "soc-postgres"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT rule_name,\n       ROUND(AVG(total_alerts)) as avg_daily_alerts,\n       ROUND(AVG(fp_rate), 1) as avg_fp_rate,\n       ROUND(AVG(quality_score), 1) as avg_quality,\n       CASE\n         WHEN AVG(quality_score) >= 80 THEN 'excellent'\n         WHEN AVG(quality_score) >= 60 THEN 'good'\n         WHEN AVG(quality_score) >= 35 THEN 'noisy'\n         ELSE 'critical'\n       END as classification\nFROM rule_performance_snapshots\nWHERE snapshot_date >= CURRENT_DATE - INTERVAL '7 days'\nGROUP BY rule_name\nORDER BY avg_fp_rate DESC\nLIMIT 10",
          "refId": "A"
        }
      ],
      "title": "Top 10 Regras Mais Ruidosas (7 dias)",
      "type": "table"
    }
